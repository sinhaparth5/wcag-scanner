{
  "name": "wcag-scanner",
  "version": "1.2.66",
  "description": "Scan HTML for WCAG accessibility violations with AI-powered fix suggestions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./react": "./dist/react/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "rimraf dist && tsc",
    "profile:aria": "npm run build && node scripts/profile-aria.js",
    "profile:contrast": "npm run build && node scripts/profile-contrast.js",
    "profile:forms": "npm run build && node scripts/profile-forms.js",
    "profile:images": "npm run build && node scripts/profile-images.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/**/*.ts",
    "codecov": "codecov"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinhaparth5/wcag-scanner.git"
  },
  "keywords": [
    "accessibility",
    "wcag",
    "ally",
    "scanner",
    "react"
  ],
  "author": "Parth Sinha",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/sinhaparth5/wcag-scanner/issues"
  },
  "homepage": "https://github.com/sinhaparth5/wcag-scanner#readme",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.8",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "codecov": "^3.6.2",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.6",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "color-diff": "^1.4.0",
    "crypto": "^1.0.1",
    "express": "^4.21.2",
    "jsdom": "^26.0.0"
  }
}
